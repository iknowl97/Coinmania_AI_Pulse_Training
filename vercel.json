{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/PREPARATION_GUIDE.html" }
  ],
  "headers": [
    {
      "source": "/setup_windows.ps1",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"setup_windows.ps1\"" }
      ]
    },
    {
      "source": "/setup_mac.sh",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"setup_mac.sh\"" }
      ]
    }
  ]
}
